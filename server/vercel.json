{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "serverless": {
          "memory": "512 MB",
          "timeout": 30
        }
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/routes/index.js"
    }
  ],
  "buildCommand": "none"
}
